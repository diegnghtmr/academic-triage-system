# Database
DB_USER=triage_user
DB_PASS=triage_secret
DB_ROOT_PASS=root_secret
DB_URL=jdbc:mariadb://localhost:3306/triage_db

# JWT
JWT_SECRET=your-256-bit-secret-change-in-production
JWT_EXPIRATION_MS=86400000

# Perfil Spring: usar `dev` en local para Flyway extra (usuario admin de desarrollo, ver README).
# Sin perfil dev, el baseline de migraciones no vuelve a crear ese admin.
SPRING_PROFILES_ACTIVE=dev

# Documentación OpenAPI (alineado con application.yml: por defecto desactivado fuera de dev/test)
APP_DOCS_ENABLED=false
APP_DOCS_PUBLIC_ENABLED=false

# IA opcional (`none` hasta configurar proveedor y chat model; ver bootstrap/application.yml)
APP_AI_PROVIDER=none
SPRING_AI_MODEL_CHAT=none
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_OPENAI_BASE_URL=
SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=gpt-4o-mini
